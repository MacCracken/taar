# taar test suite — pure-code coverage of the substrate surface.
#
# Stdlib auto-included via cyrius.cyml. Network paths (UDP/ICMP
# send/recv) are exercised by the real consumer binaries (yo, dig)
# rather than this suite — too much variance vs. a live host to make
# for reliable CI. Pure codecs live here.

include "src/ipv4.cyr"
include "src/socket.cyr"
include "src/dns.cyr"

# === IPv4 parser ===
fn test_ipv4_parse() {
    test_group("ipv4_parse");
    # Valid.
    assert_eq(ipv4_parse("0.0.0.0"),         0x00000000, "ipv4 zeros");
    assert_eq(ipv4_parse("127.0.0.1"),       0x7F000001, "ipv4 loopback");
    assert_eq(ipv4_parse("8.8.8.8"),         0x08080808, "ipv4 google");
    assert_eq(ipv4_parse("192.168.1.1"),     0xC0A80101, "ipv4 gateway");
    assert_eq(ipv4_parse("255.255.255.255"), 0xFFFFFFFF, "ipv4 broadcast");
    assert_eq(ipv4_parse("10.0.2.15"),       0x0A00020F, "ipv4 slirp guest");
    # Rejection cases.
    assert_eq(ipv4_parse("256.0.0.0"),  IPV4_PARSE_FAIL, "ipv4 octet > 255");
    assert_eq(ipv4_parse("1.2.3"),      IPV4_PARSE_FAIL, "ipv4 only 3 octets");
    assert_eq(ipv4_parse("1.2.3.4.5"),  IPV4_PARSE_FAIL, "ipv4 5 octets");
    assert_eq(ipv4_parse("1.2..4"),     IPV4_PARSE_FAIL, "ipv4 empty segment");
    assert_eq(ipv4_parse(""),           IPV4_PARSE_FAIL, "ipv4 empty string");
    assert_eq(ipv4_parse("1.2.3.4 "),   IPV4_PARSE_FAIL, "ipv4 trailing space");
    assert_eq(ipv4_parse("1234.0.0.0"), IPV4_PARSE_FAIL, "ipv4 4-digit octet");
    return 0;
}

# === IPv4 format — round-trip ===
fn test_ipv4_format() {
    test_group("ipv4_format");
    var b = alloc(16);
    var n = ipv4_format_to_buf(0x7F000001, b);
    store8(b + n, 0);
    assert_eq(streq(b, "127.0.0.1"), 1, "ipv4 format loopback");
    n = ipv4_format_to_buf(0xFFFFFFFF, b);
    store8(b + n, 0);
    assert_eq(streq(b, "255.255.255.255"), 1, "ipv4 format broadcast");
    n = ipv4_format_to_buf(0xC0A80101, b);
    store8(b + n, 0);
    assert_eq(streq(b, "192.168.1.1"), 1, "ipv4 format gateway");
    # Round-trip: parse(format(x)) == x.
    n = ipv4_format_to_buf(0x08080808, b);
    store8(b + n, 0);
    assert_eq(ipv4_parse(b), 0x08080808, "ipv4 round-trip 8.8.8.8");
    return 0;
}

# === socket: sockaddr_in builder (pure; the syscalls smoke against a live host) ===
fn test_sockaddr() {
    test_group("sockaddr");
    var sa = alloc(16);
    taar_fill_sockaddr(sa, 0xC0A80101, 53);   # 192.168.1.1 : 53
    assert_eq(load8(sa + 0), 2,   "AF_INET low byte");
    assert_eq(load8(sa + 1), 0,   "AF_INET high byte");
    assert_eq(load8(sa + 2), 0,   "port hi (53>>8)");
    assert_eq(load8(sa + 3), 53,  "port lo");
    assert_eq(load8(sa + 4), 192, "addr octet 0");
    assert_eq(load8(sa + 5), 168, "addr octet 1");
    assert_eq(load8(sa + 6), 1,   "addr octet 2");
    assert_eq(load8(sa + 7), 1,   "addr octet 3");
    # a port spanning both bytes: 443 = 0x01BB
    taar_fill_sockaddr(sa, 0x08080808, 443);
    assert_eq(load8(sa + 2), 1,   "port hi (443>>8 = 1)");
    assert_eq(load8(sa + 3), 187, "port lo (443 & 0xFF = 187)");
    return 0;
}

# === dns: wire framing (pure; the live resolve is a smoke) ===
fn test_dns_encode() {
    test_group("dns-encode");
    var out = alloc(64);
    var n = _taar_dns_encode_name("example.com", out);
    assert_eq(n, 13, "encode len (example.com)");
    assert_eq(load8(out + 0), 7, "label1 length = 7");
    assert_eq(load8(out + 1), 101, "label1[0] = 'e'");
    assert_eq(load8(out + 8), 3, "label2 length = 3");
    assert_eq(load8(out + 12), 0, "root label terminator");
}

fn test_dns_build() {
    test_group("dns-build");
    var qb = alloc(300);
    var ql = _taar_dns_build_query(qb, 0xABCD, "a.bc");
    assert_eq(ql, 22, "query len for a.bc (12 + 6 + 4)");
    assert_eq(load8(qb + 0), 171, "id hi byte (0xAB)");
    assert_eq(load8(qb + 1), 205, "id lo byte (0xCD)");
    assert_eq(load8(qb + 2), 1, "RD flag hi byte (0x01)");
    assert_eq(load8(qb + 5), 1, "qdcount lo = 1");
}

# Hand-build a minimal A response (example.com -> 93.184.216.34). Returns length.
fn _canned_a_response(buf): i64 {
    _taar_dns_store_u16(buf, 0, 0x1234);   # id
    _taar_dns_store_u16(buf, 2, 0x8180);   # QR|RD|RA, rcode NOERROR
    _taar_dns_store_u16(buf, 4, 1);        # qdcount
    _taar_dns_store_u16(buf, 6, 1);        # ancount
    _taar_dns_store_u16(buf, 8, 0);
    _taar_dns_store_u16(buf, 10, 0);
    var n = _taar_dns_encode_name("example.com", buf + 12);
    var off = 12 + n;
    _taar_dns_store_u16(buf, off, 1); off = off + 2;   # qtype A
    _taar_dns_store_u16(buf, off, 1); off = off + 2;   # qclass IN
    store8(buf + off, 0xC0); store8(buf + off + 1, 0x0C); off = off + 2;   # answer name ptr -> 12
    _taar_dns_store_u16(buf, off, 1); off = off + 2;   # type A
    _taar_dns_store_u16(buf, off, 1); off = off + 2;   # class IN
    store8(buf + off, 0); store8(buf + off + 1, 0); store8(buf + off + 2, 0x0E); store8(buf + off + 3, 0x10); off = off + 4;   # ttl 3600
    _taar_dns_store_u16(buf, off, 4); off = off + 2;   # rdlength
    store8(buf + off, 93); store8(buf + off + 1, 184); store8(buf + off + 2, 216); store8(buf + off + 3, 34); off = off + 4;
    return off;
}

fn test_dns_parse_a() {
    test_group("dns-parse-a");
    var buf = alloc(128);
    var len = _canned_a_response(buf);
    assert_eq(_taar_dns_hdr_ancount(buf), 1, "ancount = 1");
    assert_eq(_taar_dns_hdr_rcode(buf), 0, "rcode NOERROR");
    assert_eq(_taar_dns_first_a(buf, len), 0x5DB8D822, "A record 93.184.216.34");
}

fn main() {
    alloc_init();
    test_ipv4_parse();
    test_ipv4_format();
    test_sockaddr();
    test_dns_encode();
    test_dns_build();
    test_dns_parse_a();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
